# Local dev: Next.js rewrites same-origin /api/* to this backend.
NEXT_PUBLIC_SSUAI_API_BASE=http://localhost:8080

# Production (Vercel): backend proxy target. Browser code still calls same-origin /api/*.
# NEXT_PUBLIC_SSUAI_API_BASE=https://ssumcp.duckdns.org

# (server-only, optional) Overrides the /api/* proxy target ahead of NEXT_PUBLIC_SSUAI_API_BASE.
# SSUAI_API_PROXY_TARGET=https://ssumcp.duckdns.org

# (server-only) ssuAgent origin used by the /api/agent/{stream,resume} proxy.
# Falls back to NEXT_PUBLIC_SSUAGENT_BASE_URL, then https://ssuagent.duckdns.org.
# SSUAGENT_BASE_URL=http://localhost:8000

# (public, legacy) ssuAgent origin fallback — mainly for local dev.
# NEXT_PUBLIC_SSUAGENT_BASE_URL=http://localhost:8000

# (server-only) X-Agent-Key credential injected by the /api/agent proxy.
# Never exposed to the browser. If unset, the header is omitted (ssuAgent gate no-op).
# AGENT_API_KEY=
